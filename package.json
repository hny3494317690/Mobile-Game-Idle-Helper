{
  "name": "mobile-game-idle-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:scrcpy-server": "fetch-scrcpy-server 3.3.3 && mkdir -p resources && cp node_modules/@yume-chan/fetch-scrcpy-server/server.bin resources/scrcpy-server.jar",
    "build": "vite build --config config/vite.config.js",
    "dev": "vite --config config/vite.config.js",
    "bridge": "node server/bridge.js",
    "preview:prod": "node server/static.js",
    "start": "vite --config config/vite.config.js"
  },
  "dependencies": {
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-scrcpy": "^2.3.2",
    "@yume-chan/fetch-scrcpy-server": "^1.0.0",
    "@yume-chan/scrcpy": "^2.3.0",
    "@yume-chan/scrcpy-decoder-webcodecs": "^2.5.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "vite": "^7.1.10"
  }
}
